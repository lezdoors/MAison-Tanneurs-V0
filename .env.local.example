# Maison Tanneurs V0 — required env vars
# Populate on Vercel (Production + Preview). Local: copy to .env.local.

# --- Supabase (canonical product data) -------------------------------------
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- Revolut Acquiring (PSP) -----------------------------------------------
# Same Akal Digital Services Ltd merchant account as the preview deploy.
# Approved 2026-05-21.
REVOLUT_API_BASE="https://merchant.revolut.com/api"
REVOLUT_SECRET_KEY=""
REVOLUT_WEBHOOK_SECRET=""
NEXT_PUBLIC_REVOLUT_PUBLIC_KEY=""

# --- Site canonical URL ----------------------------------------------------
# Used for absolute image URLs in Revolut line_items and the open-redirect-safe
# redirect_url on checkout. Fail-closed if unset — Host header is not trusted.
NEXT_PUBLIC_SITE_URL="https://www.maisontanneurs.com"

# --- Resend (transactional email) ------------------------------------------
# Sender: orders@maisontanneurs.com (domain must be verified in Resend).
# Admin notifications go to haddaoui.ops@outlook.com.
RESEND_API_KEY=""

# --- Meta Pixel + Conversions API ------------------------------------------
# Same Pixel id used client-side (NEXT_PUBLIC_) and server-side (CAPI).
NEXT_PUBLIC_META_PIXEL_ID="26891834623830253"
META_PIXEL_ID="26891834623830253"
META_CAPI_ACCESS_TOKEN=""

# --- Telegram alerts (optional, kept for redundancy with Resend) -----------
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
